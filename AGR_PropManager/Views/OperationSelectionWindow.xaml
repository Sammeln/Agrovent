<!-- File: Views/OperationSelectionWindow.xaml -->
<Window x:Class="AGR_PropManager.Views.OperationSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:AGR_PropManager.Views"        
        xmlns:vm="clr-namespace:AGR_PropManager.ViewModels.TechProcess"
        mc:Ignorable="d"
        Title="Выбор операции" Height="450" Width="600"
        d:DataContext="{d:DesignInstance Type=vm:OperationSelectionViewModel, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Панель поиска -->
        <Border Grid.Row="0" Background="LightGray" Padding="10" Margin="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Label Content="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="SearchWorkstationTextBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="150" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="OperationsDataGrid"
                  ItemsSource="{Binding TemplateOperationsView}" 
                  SelectedItem="{Binding SelectedOperation}" 
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <!-- Участок -->
                <DataGridTextColumn Header="Участок" Binding="{Binding WorkstationName}" Width="*" />
                <!-- Операция -->
                <DataGridTextColumn Header="Операция" Binding="{Binding Name}" Width="*" />
                <!-- Стоимость в час (опционально) -->
                <DataGridTextColumn Header="Стоимость/час" Binding="{Binding CostPerHour, StringFormat='{}{0:F2} руб.'}" Width="*" Visibility="Collapsed"/>
            </DataGrid.Columns>
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDoubleClick">
                    <i:InvokeCommandAction Command="{Binding SetOperationCommand}" CommandParameter="{Binding SelectedOperation}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </DataGrid>

        <!-- Кнопка закрытия -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="Закрыть" Command="{Binding CloseCommand}" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>