<!-- File: Views/MainWindow.xaml -->
<Window x:Class="AGR_PropManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vmComp="clr-namespace:AGR_PropManager.ViewModels.Components"
        xmlns:vmWindows="clr-namespace:AGR_PropManager.ViewModels.Windows"
        mc:Ignorable="d"
        Title="Классификатор компонентов"
        WindowState="Maximized"
        d:DataContext="{d:DesignInstance Type=vmWindows:MainWindowViewModel, IsDesignTimeCreatable=True}">

    <Window.Resources>
        <!-- ContextMenu для строки DataGrid -->
        <ContextMenu x:Key="ClassifierRowMenu">
            <MenuItem Header="Открыть"
                      CommandParameter="{Binding}"
                      Command="{Binding DataContext.OpenItemTechProcessEditorCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}" 
                      />
        </ContextMenu>

        <!-- Style для строки DataGrid -->
        <Style x:Key="ClassifierRowStyle" TargetType="DataGridRow">
            <Setter Property="ContextMenu" Value="{StaticResource ClassifierRowMenu}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Search TextBox -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Search TextBox -->
        <TextBox Grid.Row="0"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Width="300"
                 Margin="10"
                 HorizontalAlignment="Left"
                 Padding="5"/>

        <!-- Main DataGrid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding ClassifierItemsView}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  RowStyle="{StaticResource ClassifierRowStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" MinWidth="30" MaxWidth="30"/>
                <DataGridTemplateColumn MinWidth="50" MaxWidth="50">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="ToolTip">
                                <Setter.Value>
                                    <Image Source="{Binding PreviewImage}" Width="800"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="ToolTipService.InitialShowDelay" Value="50"/>
                            <Setter Property="ToolTipService.Placement" Value="Mouse"/>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding PreviewImage}" MaxHeight="50" MaxWidth="50" Stretch="Uniform"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="PartNumber" Binding="{Binding PartNumber}" Width="*"/>
                <DataGridTextColumn Header="Дата сохранения" Binding="{Binding SavedDate, StringFormat='dd.MM.yyyy'}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>