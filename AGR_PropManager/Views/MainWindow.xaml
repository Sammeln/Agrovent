<Window x:Class="AGR_PropManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:viewmodels="clr-namespace:AGR_PropManager.ViewModels"
        xmlns:enums="clr-namespace:Agrovent.Infrastructure.Enums;assembly=Agrovent.Infrastructure"
        mc:Ignorable="d"
        Title="Редактор технологического процесса" Height="720" Width="1280"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel, IsDesignTimeCreatable=True}">

    <Window.Resources>
        <ObjectDataProvider MethodName="GetValues" ObjectType="{x:Type enums:AGR_ComponentType_e}" x:Key="ComponentTypeEnum"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" ToolBarTray.IsLocked="True">
            <Label Content="PartNumber:"/>
            <TextBox x:Name="PartNumberTextBox" Text="{Binding SearchPartNumber, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="0,0,10,0"/>
            <Button Content="Загрузить структуру" Command="{Binding LoadStructureCommand}" CommandParameter="{Binding Text, ElementName=PartNumberTextBox}" Margin="0,0,10,0"/>
            <Label Content="Группировка:"/>
            <ComboBox SelectedValue="{Binding SelectedGroupingMode}" SelectedValuePath="Content" Width="120" Margin="0,0,10,0">
                <ComboBoxItem Content="По материалу"/>
                <ComboBoxItem Content="По типу"/>
            </ComboBox>
            <Button Content="Редактировать процесс" Command="{Binding EditProcessCommand}"/>
        </ToolBar>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="ComponentsDataGrid"
                  ItemsSource="{Binding ComponentsView}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Extended"
                  IsReadOnly="True">
            <!-- Используем Interaction.Triggers для обработки KeyDown -->
            <DataGrid.InputBindings>
                <KeyBinding Key="Insert" Command="{Binding HandleKeyDownCommand}"/>
            </DataGrid.InputBindings>

            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock FontWeight="Bold" Text="{Binding Name}"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </DataGrid.GroupStyle>
            <DataGrid.Columns>
                <!-- CheckBox Column -->
                <DataGridTemplateColumn Header="Выбрать">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Preview -->
                <DataGridTemplateColumn Header="Превью">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding PreviewImage}" MaxHeight="50" MaxWidth="50" Stretch="Uniform"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- PartNumber -->
                <DataGridTextColumn Header="Обозначение" Binding="{Binding PartNumber}" Width="0.8*" />

                <!-- Name -->
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="2*" />

                <!-- Quantity -->
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="0.5*" />

                <!-- Material -->
                <DataGridTextColumn Header="Материал" Binding="{Binding Material}" Width="3*" />

                <!-- Paint -->
                <DataGridTextColumn Header="Покраска" Binding="{Binding Paint}" Width="1*" />

                <!-- Bend Count -->
                <DataGridTextColumn Header="Сгибы" Binding="{Binding BendCount}" Width="0.7*" />

                <!-- Contour Length -->
                <DataGridTextColumn Header="Контур" Binding="{Binding ContourLength}" Width="0.7*" />

                <!-- ComponentType -->
                <DataGridTextColumn Header="Тип" Binding="{Binding ComponentTypeDisplay}" Width="1*" />

                <!-- Tech Process Summary -->
                <DataGridTextColumn Header="Техпроцесс" Binding="{Binding TechProcessSummary}" Width="*" />

            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Background" Value="LightBlue"/>
                        </DataTrigger>
                        <!-- Подсветка операций с TotalTime == 0 -->
                        <DataTrigger Binding="{Binding HasZeroTimeOperations}" Value="True">
                            <Setter Property="Background" Value="Red"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
    </Grid>
</Window>