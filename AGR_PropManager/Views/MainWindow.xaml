<!-- File: Views/MainWindow.xaml -->
<Window x:Class="AGR_PropManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vmComp="clr-namespace:AGR_PropManager.ViewModels.Components"
        xmlns:vmWindows="clr-namespace:AGR_PropManager.ViewModels.Windows"
        xmlns:b="clr-namespace:AGR_PropManager.Infrastructure.Behaviors"
        xmlns:AGR_Behavors="clr-namespace:Agrovent.Infrastructure.Behaviors;assembly=Agrovent.Infrastructure"
        xmlns:enums="clr-namespace:Agrovent.Infrastructure.Enums;assembly=Agrovent.Infrastructure"
        xmlns:converters="clr-namespace:Agrovent.Infrastructure.AGR_Converters;assembly=Agrovent.Infrastructure"
        mc:Ignorable="d"
        Title="Редактор технологического процесса"
        WindowState="Maximized"
        d:DataContext="{d:DesignInstance Type=vmWindows:MainWindowViewModel, IsDesignTimeCreatable=True}">

    <Window.Resources>
        <ObjectDataProvider MethodName="GetValues" ObjectType="{x:Type enums:AGR_ComponentType_e}" x:Key="ComponentTypeEnum"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:AGR_EmptyCollectionToVisibilityConverter x:Key="AGR_EmptyCollectionToVisibilityConverter"/>
        <converters:AGR_ComponentTypeConverter x:Key="ComponentTypeConverter"/>

        <!-- ContextMenu для строк классификатора -->
        <ContextMenu x:Key="ClassifierRowMenu">
            <MenuItem Header="Открыть" Command="{Binding DataContext.OpenClassifierItemCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}" 
                      CommandParameter="{Binding}"/>
        </ContextMenu>

        <Style x:Key="ClassifierRowStyle" TargetType="DataGridRow">
            <Setter Property="ContextMenu" Value="{StaticResource ClassifierRowMenu}"/>
        </Style>

        <!-- DataTemplate для отображения изображения в ячейке -->
        <DataTemplate x:Key="PreviewImageTemplate">
            <Image Source="{Binding PreviewImage}" MaxHeight="50" MaxWidth="50" Stretch="Uniform"/>
        </DataTemplate>

        <!-- DataTemplate для вкладки классификатора -->
        <DataTemplate x:Key="ClassifierContentTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Строка поиска -->
                <DockPanel Grid.Row="0" Margin="5">
                    <Label Content="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             MinWidth="200"/>
                </DockPanel>

                <!-- DataGrid классификатора -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ClassifierItemsView}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          Style="{StaticResource ClassifierRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="0.3*"/>
                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="ToolTip">
                                        <Setter.Value>
                                            <Image Source="{Binding PreviewImage}" Width="800"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="ToolTipService.InitialShowDelay" Value="50"/>
                                    <Setter Property="ToolTipService.Placement" Value="Mouse"/>
                                </Style>
                            </DataGridTemplateColumn.CellStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding PreviewImage}" MaxHeight="50" MaxWidth="50" Stretch="Uniform"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="PartNumber" Binding="{Binding PartNumber}" Width="*"/>
                        <DataGridTextColumn Header="Дата сохранения" Binding="{Binding SavedDate, StringFormat='dd.MM.yyyy'}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="OperationsTemplate" DataType="vmComp:ComponentItemViewModel">
            <DataGrid x:Name="OperationsGrid"
                      ItemsSource="{Binding Operations, NotifyOnSourceUpdated=True}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      RowHeight="25" MinHeight="30" MaxHeight="200"
                      Visibility="{Binding Operations.Count, Converter={StaticResource AGR_EmptyCollectionToVisibilityConverter}}">
                
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding SequenceNumber}" Width="0.2*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Участок" Binding="{Binding WorkstationName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Операция" Binding="{Binding Name}" Width="3*" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Время" Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CostPerHour, StringFormat='{}{0:F2} мин'}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding CostPerHour}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CostPerHour}" Value="0">
                                <Setter Property="Background" Value="IndianRed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                
                <i:Interaction.Behaviors>
                    <b:TestBehavior/>
                </i:Interaction.Behaviors>
                <DataGrid.InputBindings>
                    <KeyBinding Key="Delete" Command="{Binding DeleteOperationCommand}" 
                                CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid, Mode=FindAncestor}}"/>
                </DataGrid.InputBindings>
            </DataGrid>
        </DataTemplate>

        <!-- DataTemplate для вкладки редактирования техпроцесса -->
        <DataTemplate x:Key="TechProcessEditorTemplate" DataType="vmComp:ComponentItemViewModel">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar с выпадающим списком -->
                <ToolBar Grid.Row="0" ToolBarTray.IsLocked="True">
                    <Label Content="Выберите операцию:"/>
                    <ComboBox ItemsSource="{Binding DataContext.TemplateOperations, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.SelectedTemplateOperation, RelativeSource={RelativeSource AncestorType=Window}}"
                              DisplayMemberPath="Name"
                              Width="200" Margin="0,0,10,0"/>
                    <Button Content="Добавить операцию" Command="{Binding DataContext.AddOperationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" Margin="0,0,10,0"/>
                    <Button Content="Сохранить" Command="{Binding DataContext.SaveTechProcessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"/>
                </ToolBar>

                <!-- DataGrid со структурой изделия -->
                <DataGrid Grid.Row="1" Grid.Column="0"
                          ItemsSource="{Binding Operations}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="True"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          IsReadOnly="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Binding="{Binding SequenceNumber}" Width="0.2*"/>
                        <DataGridTextColumn Header="Участок" Binding="{Binding WorkstationName}" Width="*"/>
                        <DataGridTextColumn Header="Операция" Binding="{Binding Name}" Width="3*"/>
                        <DataGridTemplateColumn Header="Время (мин)" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CostPerHour, StringFormat='{}{0:F2}'}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding CostPerHour, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CostPerHour}" Value="0">
                                    <Setter Property="Background" Value="IndianRed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>

                <!-- Border с ошибками валидации -->
                <Border Grid.Row="1" Grid.Column="1" 
                        BorderBrush="Red" BorderThickness="1" 
                        Background="#FFFDE7" Padding="10" Margin="5,0,0,0"
                        MinWidth="200">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ValidationErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Меню с отчетами -->
        <Menu Grid.Row="0">
            <MenuItem Header="_Отчеты">
                <MenuItem Header="Отчет импорта классификатора" Command="{Binding ShowImportClassifierReportCommand}"/>
                <MenuItem Header="Отчет импорта дерева" Command="{Binding ShowTreeImportReportCommand}"/>
                <MenuItem Header="Отчет импорта техопераций" Command="{Binding ShowTechOpsImportReportCommand}"/>
            </MenuItem>
        </Menu>

        <!-- TabControl -->
        <TabControl Grid.Row="1" 
                    ItemsSource="{Binding OpenTabs}"
                    SelectedItem="{Binding SelectedTab}"
                    x:Name="MainTabControl">
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="ContentTemplate" Value="{StaticResource TechProcessEditorTemplate}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsClassifierTab}" Value="True">
                                        <Setter Property="ContentTemplate" Value="{StaticResource ClassifierContentTemplate}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </DataTemplate>
            </TabControl.ContentTemplate>
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding TabHeader}" Margin="5,0,0,0"/>
                        <Button Content="✕" Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                CommandParameter="{Binding}" 
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="10,0,0,0" Padding="2,0,2,0"
                                FontSize="10" FontWeight="Bold"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>
    </Grid>
</Window>
