<!-- File: Views/Reports/TreeImportReportView.xaml -->
<Window x:Class="AGR_PropManager.Views.Reports.TreeImportReportWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AGR_PropManager.Views.Reports"
             xmlns:vmRep="clr-namespace:AGR_PropManager.ViewModels.Reports"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vmRep:TreeImportReportViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Button and status bar -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="10">
            <TextBlock Text="Отчет импорта дерева" FontSize="18" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                <Button Content="Сохранить в Excel" Command="{Binding ExportToExcelCommand}"/>
            </StackPanel>
        </StackPanel>

        <DataGrid x:Name="ReportDataGrid" Grid.Row="1"
                  ItemsSource="{Binding ReportData, Mode=OneWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Margin="10"
                  HeadersVisibility="Column">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasErrors}" Value="True">
                            <Setter Property="Background" Value="IndianRed"/>
                            <Setter Property="ToolTip" Value="{Binding ErrorTooltip}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование главного артикула" Binding="{Binding MainArtName}" Width="2*" />
                <DataGridTextColumn Header="Part Number главного артикула" Binding="{Binding MainPartNumber}" Width="0.5*" />
                <DataGridTextColumn Header="Part Number child" Binding="{Binding ChildPartNumber}" Width="0.5*" />
                <DataGridTextColumn Header="Наименование child" Binding="{Binding ChildName}" Width="2*" />
                <DataGridTextColumn Header="Артикул AVA гл.артикула" Binding="{Binding MainArticleAVA}" Width="0.5*" />
                <DataGridTextColumn Header="Артикул AVA child" Binding="{Binding ChildArticleAVA}" Width="0.5*" />
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, StringFormat=F2}" Width="0.5*" />
                <!-- F2 for 2 decimal places -->
                <!-- Columns 7-10: Пусто -->
                <DataGridTextColumn Header="" IsReadOnly="True" />
                <DataGridTextColumn Header="" IsReadOnly="True" />
                <DataGridTextColumn Header="" IsReadOnly="True" />
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header="ЕИ child" Binding="{Binding ChildUnit}" Width="0.5*" />
                <!-- Columns 12-13: Пусто -->
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header="Тип child" Binding="{Binding ChildType}" Width="1*" />
                <!-- Columns 15 Пусто -->
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header=""  IsReadOnly="True" />
                <DataGridTextColumn Header="URL child" Binding="{Binding ChildURL}" Width="3*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
    </Window>