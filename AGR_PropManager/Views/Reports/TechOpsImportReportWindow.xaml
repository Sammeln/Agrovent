<Window x:Class="AGR_PropManager.Views.Reports.TechOpsImportReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AGR_PropManager.Views.Reports"
             xmlns:vmRep="clr-namespace:AGR_PropManager.ViewModels.Reports"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vmRep:TechOpsImportReportViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Button and status bar -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="10">
            <TextBlock Text="Отчет импорта техопераций" FontSize="18" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                <Button Content="Сохранить в Excel" Command="{Binding ExportToExcelCommand}"/>
            </StackPanel>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding ReportData, Mode=OneWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Margin="10"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding ComponentName}" Width="*" />
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article, TargetNullValue=''}" Width="*" />
                <DataGridTextColumn Header="Partnumber" Binding="{Binding Partnumber}" Width="*" />
                <DataGridTextColumn Header="" IsReadOnly="True" />
                <DataGridTextColumn Header="" IsReadOnly="True" />
                <DataGridTextColumn Header="Трудоемкость" Binding="{Binding LabourIntensity, StringFormat=F3}" Width="*" />
                <DataGridTextColumn Header="" IsReadOnly="True" />
                <DataGridTextColumn Header="" IsReadOnly="True" />
                <DataGridTextColumn Header="Доступность" Binding="{Binding Availability}" Width="*" />
                <DataGridTextColumn Header="Порядок" Binding="{Binding Order}" Width="*" />
                <DataGridTextColumn Header="Добавочная" Binding="{Binding Additional}" Width="*" />
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding LabourIntensity}" Value="0">
                            <Setter Property="Background" Value="IndianRed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            
        </DataGrid>
    </Grid>
</Window>
