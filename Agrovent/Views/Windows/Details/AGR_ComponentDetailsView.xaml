<!-- File: Views/Windows/Details/AGR_ComponentDetailsView.xaml -->
<UserControl x:Class="Agrovent.Views.Windows.Details.AGR_ComponentDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Agrovent.Views.Windows.Details"
             xmlns:vm="clr-namespace:Agrovent.ViewModels.Windows.Details"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AGR_ComponentDetailsVM, IsDesignTimeCreatable=True}"
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer>
        <StackPanel Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Превью -->
                <Image Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Source="{Binding Preview}" MaxHeight="100" MaxWidth="100" Stretch="Uniform" Margin="0,0,10,0" />

                <!-- Основная информация -->
                <StackPanel Grid.Row="0" Grid.Column="1">
                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="{Binding PartNumber}" FontSize="12" Foreground="Gray" />
                    <TextBlock Text="{Binding CreatedAt, StringFormat='Дата сохранения: dd.MM.yyyy HH:mm:ss'}" />
                    <TextBlock Text="{Binding ComponentTypeDisplay, StringFormat='Тип: {0}'}" />
                    <TextBlock Text="{Binding AvaTypeDisplay, StringFormat='AvaType: {0}'}" />
                    <TextBlock Text="{Binding Version, StringFormat='Версия: {0}'}" />
                    <TextBlock Text="{Binding StoragePath, StringFormat='Путь: {0}'}" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Дополнительная информация -->
                <Expander Grid.Row="1" Grid.Column="1" Header="Дополнительная информация" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding MaterialName, StringFormat='Материал: {0}'}" />
                        <TextBlock Text="{Binding MaterialUOM, StringFormat='Ед. изм.: {0}'}" />
                        <TextBlock Text="{Binding MaterialArticle, StringFormat='Article: {0}'}" />
                        <TextBlock Text="{Binding PaintName, StringFormat='Покраска: {0}'}" />
                        <TextBlock Text="{Binding PaintArticle, StringFormat='Article покраски: {0}'}" />

                        <TextBlock Text="Технологический процесс:" FontWeight="Bold" Margin="0,10,0,0"/>
                        <ItemsControl ItemsSource="{Binding TechProcessSteps}" />
                    </StackPanel>
                </Expander>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>