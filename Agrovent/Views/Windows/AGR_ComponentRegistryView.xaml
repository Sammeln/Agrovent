<!-- File: Views/Windows/AGR_ComponentRegistryView.xaml -->
<Window x:Class="Agrovent.Views.Windows.AGR_ComponentRegistryView"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:vm="clr-namespace:Agrovent.ViewModels.Components"
            xmlns:window="clr-namespace:Agrovent.ViewModels.Windows"
            xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
            xmlns:local="clr-namespace:Agrovent.Views.Windows"
            xmlns:behaviors="clr-namespace:Agrovent.Infrastructure.Behaviours" 
            mc:Ignorable="d"
            d:DataContext="{d:DesignInstance Type=vm:AGR_ComponentRegistryItemVM, IsDesignTimeCreatable=True}"
            d:DesignHeight="600" d:DesignWidth="1000">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Подключаем стили из PartComponentStyles.xaml -->
                <ResourceDictionary Source="../../Resources/Styles/PartComponentStyles.xaml"/>
                <!-- Подключаем стили спецификации -->
                <ResourceDictionary Source="../../Resources/Styles/SpecificationStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- DataTemplate для отображения изображения в ячейке -->
            <DataTemplate x:Key="PreviewImageTemplate">
                <Image Source="{Binding Preview}" MaxHeight="50" MaxWidth="50" Stretch="Uniform" />
            </DataTemplate>

            <!-- DataTemplate для отображения компонента в ListView -->
            <DataTemplate x:Key="ComponentListItemTemplate">
                <Border Background="LightGray" BorderBrush="Black" BorderThickness="1" Padding="5" Margin="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Превью -->
                        <Image Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Source="{Binding Preview}" MaxHeight="50" MaxWidth="50" Stretch="Uniform" Margin="0,0,5,0" />

                        <!-- Наименование -->
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" />

                        <!-- PartNumber -->
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PartNumber}" />

                        <!-- Тип компонента -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding ComponentTypeDisplay}" FontStyle="Italic" />

                        <!-- Путь в хранилище -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding StoragePath}" TextWrapping="Wrap" />

                    </Grid>
                </Border>
            </DataTemplate>

            <!-- ContextMenu -->
            <ContextMenu  x:Key="RowMenu" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <MenuItem Header="Открыть" CommandParameter="{Binding}"
                    Command="{Binding DataContext.OpenComponentCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}" />
                <MenuItem Header="Вставить в сборку" CommandParameter="{Binding}"
                    Command="{Binding DataContext.AddToAssemblyCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}" />
                <MenuItem Header="Подробная информация" CommandParameter="{Binding}"
                    Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}" />
            </ContextMenu>
            <Style x:Key="DefaultRowStyle" TargetType="{x:Type DataGridRow}">
                <Setter Property="ContextMenu" Value="{StaticResource RowMenu}" />
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <TabControl >
        <TabItem Visibility="Hidden">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Панель поиска -->
            <Border Grid.Row="0" Background="LightGray" Padding="10" Margin="5">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="SearchTextBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="200" />
                </StackPanel>
            </Border>

            <!-- DataGrid -->
            <DataGrid Grid.Row="1"
                      x:Name="RegistryDataGrid"
                      ItemsSource="{Binding RegistryItemsView}" 
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      IsReadOnly="True"
                      RowStyle="{StaticResource DefaultRowStyle}">
                <DataGrid.Columns>
                    
                    
                    <!-- Превью -->
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <Image Source="{Binding Preview}" Width="1000"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="ToolTipService.InitialShowDelay" Value="50" />
                                <Setter Property="ToolTipService.Placement" Value="Right"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:AGR_ComponentRegistryItemVM}">
                                <!-- Контейнер для основного отображения в ячейке -->
                                <Image Source="{Binding Preview}" MaxHeight="50" MaxWidth="50" Stretch="Uniform"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Наименование -->
                    <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="2*" />
                    <!-- PartNumber -->
                    <DataGridTextColumn Header="Обозначение" Binding="{Binding PartNumber}" Width="1.5*" />
                    <!-- Дата создания -->
                    <DataGridTextColumn Header="Дата сохранения" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm:ss'}" Width="*" />
                    <!-- ComponentType -->
                    <DataGridTextColumn Header="Тип компонента" Binding="{Binding ComponentTypeDisplay, Converter={StaticResource ComponentTypeConverter}}" Width="*" />
                    <!-- AvaType -->
                    <DataGridTextColumn Header="Тип Ava" Binding="{Binding AvaTypeDisplay, Converter={StaticResource AvaTypeConverter}}" Width="*" />
                    <!-- Версия -->
                    <DataGridTextColumn Header="Версия" Binding="{Binding Version}" Width="*" />
                    <!-- Путь к файлу -->
                    <DataGridTextColumn Header="Путь в хранилище" Binding="{Binding StoragePath}" Width="3*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        </TabItem>
        
        <!-- Новая вкладка ListView -->
        <TabItem Header="Список" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Панель поиска (можно оставить или удалить, если используется фильтр из DataGrid) -->
                <Border Grid.Row="0" Background="LightGray" Padding="10" Margin="5">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="SearchTextBoxList"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" MinWidth="200" />
                    </StackPanel>
                </Border>

                <!-- ListView -->
                <ListView Grid.Row="1"
                            x:Name="RegistryListView"
                            ItemsSource="{Binding RegistryItemsView}" 
                            ItemTemplate="{StaticResource ComponentListItemTemplate}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <EventSetter Event="PreviewMouseMove" Handler="ListViewItem_PreviewMouseMove" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </TabItem>
    </TabControl>
</Window>