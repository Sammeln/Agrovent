<Window x:Class="Agrovent.Views.Windows.AGR_SpecificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Agrovent.Views.Windows"
        xmlns:vm="clr-namespace:Agrovent.ViewModels.Specification"
        xmlns:converter="clr-namespace:Agrovent.Infrastructure.Converters"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:b="clr-namespace:Agrovent.Infrastructure.Behaviors;assembly=Agrovent.Infrastructure"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        d:DataContext="{d:DesignInstance Type={x:Type vm:AGR_SpecificationViewModel}}"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" 
        Height="700" 
        Width="1200"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Подключаем стили из PartComponentStyles.xaml -->
                <ResourceDictionary Source="../../Resources/Styles/PartComponentStyles.xaml"/>
                <!-- Подключаем стили спецификации -->
                <ResourceDictionary Source="../../Resources/Styles/SpecificationStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Конвертеры -->
            <converter:GroupHeaderColorConverter x:Key="GroupHeaderColorConverter"/>
            <!--<converter:AGR_ComponentTypeConverter x:Key="ComponentTypeConverter"/>-->
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>


            <DataTemplate DataType="{x:Type ImageSource}">
                <Image Source="{Binding}" MaxHeight="200" MaxWidth="200" Stretch="Uniform" />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:AGR_SpecificationItemVM}">
                <Image Source="{Binding Preview}" MaxHeight="200" MaxWidth="200" Stretch="Uniform" />
            </DataTemplate>

            <!-- ContextMenu -->
            <ContextMenu  x:Key="RowMenu" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <MenuItem 
                     Header="Установить материал" CommandParameter="{Binding}"
                     Command="{Binding DataContext.SetBaseMaterialCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}" />
                <MenuItem 
                     Header="Установить покрытие...">
                    <MenuItem 
                         Header="Найти артикул" CommandParameter="{Binding}"
                         Command="{Binding DataContext.SetPaintCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"/>
                    <MenuItem 
                         Header="Без покрытия" CommandParameter="NoPaint"
                         Command="{Binding DataContext.SetPaintCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"/>
                        
                </MenuItem>
                    <MenuItem 
                     Header="Установить артикул" CommandParameter="{Binding}"
                     Command="{Binding DataContext.SetAvaArticleCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}" />
                    <MenuItem 
                     Header="Установить тип...">
                        <MenuItem Header="Покупное" CommandParameter="20021" 
                              Command="{Binding DataContext.SetAvaTypeCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}" />
                        <MenuItem Header="Комплектующая" CommandParameter="5" 
                              Command="{Binding DataContext.SetAvaTypeCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}" />
                        <MenuItem Header="Продукция" CommandParameter="3" 
                              Command="{Binding DataContext.SetAvaTypeCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}" />
                        <MenuItem Header="Виртуальный компонент" CommandParameter="50625" 
                              Command="{Binding DataContext.SetAvaTypeCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}" />
                    </MenuItem>
            </ContextMenu>

            <!-- Конвертеры видимости для разных типов компонентов -->
            <!--<converter:ComponentTypeToVisibilityConverter x:Key="MaterialVisibilityConverter" 
                Parameter="Part,SheetMetallPart"/>
            <converter:ComponentTypeToVisibilityConverter x:Key="PaintVisibilityConverter" 
                Parameter="Assembly,Part,SheetMetallPart"/>
            <converter:ComponentTypeToVisibilityConverter x:Key="ThicknessVisibilityConverter" 
                Parameter="SheetMetallPart"/>-->

        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок окна -->
        <Border Grid.Row="0" Style="{StaticResource WindowHeaderStyle}">
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="{Binding WindowTitle}" 
                           Foreground="White" 
                           FontSize="16" 
                           FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Основной контент - DataGrid с группировкой -->
        <Grid Grid.Row="2" Margin="16">
            <Grid.Resources>
                <!-- CollectionViewSource для группировки компонентов -->
                <CollectionViewSource x:Key="1GroupedComponents" 
                                      Source="{Binding Components, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}">
                    <CollectionViewSource.GroupDescriptions>
                        <PropertyGroupDescription PropertyName="ComponentType"/>
                    </CollectionViewSource.GroupDescriptions>
                    <CollectionViewSource.SortDescriptions>
                        <scm:SortDescription PropertyName="ComponentType" Direction="Ascending"/>
                        <scm:SortDescription PropertyName="Name" Direction="Ascending"/>
                    </CollectionViewSource.SortDescriptions>
                </CollectionViewSource>
            </Grid.Resources>

            <!-- DataGrid с группировкой -->
            <!--ItemsSource="{Binding  Source={StaticResource GroupedComponents}}"-->
            <DataGrid ItemsSource="{Binding GroupedComponentsView}"
                      Style="{StaticResource SpecificationDataGrid}"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      b:AGR_DataGridSelectedItemsBehavior.SelectedItems="{Binding SelectedComponents, Mode=TwoWay}"
                      >

                <DataGrid.InputBindings>
                    <KeyBinding Key="Space" Command="{Binding SelectComponentCommand}"/>
                    <MouseBinding Gesture="RightClick" Command="{Binding SelectComponentCommand}"/>
                </DataGrid.InputBindings>
                

                <!-- Настройка группировки -->
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}" BasedOn="{StaticResource GroupHeaderStyle}"/>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </DataGrid.GroupStyle>

                <!-- Колонки DataGrid -->
                <DataGrid.Columns>

                    <DataGridTemplateColumn Width="25">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Preview Column -->
                    <DataGridTemplateColumn Width="50" MinWidth="50">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <Image Source="{Binding Preview}" Width="450"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="ToolTipService.InitialShowDelay" Value="50" />
                                <Setter Property="ToolTipService.Placement" Value="Right"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:AGR_SpecificationItemVM}">
                                <!-- Контейнер для основного отображения в ячейке -->
                                <Image Source="{Binding Preview}" MaxHeight="50" MaxWidth="50" Stretch="Uniform"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Наименование -->
                    <DataGridTextColumn Header="Наименование" 
                                        Binding="{Binding Name}" 
                                        Width="3*"
                                        CanUserSort="True"
                                        ElementStyle="{StaticResource VerticalAlignedTextStyle}"
                                        >
                    </DataGridTextColumn>

                    <!-- PartNumber/Артикул -->
                    <DataGridTextColumn Header="PartNumber / Артикул" 
                                        Width="2*"
                                        CanUserSort="True"
                                        ElementStyle="{StaticResource CenterAlignedTextStyle}"
                                        Binding="{Binding PartnumberOrArticle}">
                    </DataGridTextColumn>

                    <!-- Количество -->
                    <DataGridTextColumn Header="Количество" 
                                        Binding="{Binding Quantity}" 
                                        Width="*"
                                        CanUserSort="True"
                                        ElementStyle="{StaticResource CenterAlignedTextStyle}"/>

                    <!-- Толщина -->
                    <DataGridTextColumn Header="Толщина" 
                                        Binding="{Binding SheetMetalThickness}" 
                                        Width="*"
                                        ElementStyle="{StaticResource CenterAlignedTextStyle}"/>

                    <!-- Материал -->
                    <DataGridTextColumn Header="Материал" 
                                        Binding="{Binding MaterialName}" 
                                        Width="4*"
                                        />

                    <!-- Краска -->
                    <DataGridTextColumn Header="Краска" 
                                        Binding="{Binding PaintName}" 
                                        Width="2*"
                                        ElementStyle="{StaticResource CenterAlignedTextStyle}"/>

                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="LightBlue"/>
                            </DataTrigger>
                        </Style.Triggers>
                        <Setter Property="ContextMenu" Value="{StaticResource RowMenu}"/>
                    </Style>
                </DataGrid.RowStyle>

            </DataGrid>

            <!-- Сообщение при отсутствии компонентов -->
            <!--<TextBlock Text="Нет компонентов для отображения" 
                       Style="{StaticResource EmptySpecificationStyle}"
                       Visibility="{Binding HasComponents, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}"/>-->
        </Grid>

        <!-- Панель действий -->
        <Border Grid.Row="3" 
                Background="White" 
                Padding="16,12" 
                BorderBrush="#E0E0E0" 
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                <Button Content="Обновить" 
                        Style="{StaticResource ActionButtonStyle}"
                        Command="{Binding RefreshCommand}"/>

                <Button Content="Экспорт в Excel" 
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="12,0,0,0"
                        Background="#4CAF50" 
                        Foreground="White"/>

                <Button Content="Печать" 
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="12,0,0,0"
                        Background="#2196F3" 
                        Foreground="White"/>

                <Button Content="Закрыть" 
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="12,0,0,0"
                        Command="{Binding CloseCommand}"
                        Background="#F44336" 
                        Foreground="White"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>