<!-- File: Views/Windows/SaveProgressView.xaml -->
<Window x:Class="Agrovent.Views.Windows.SaveProgressView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Agrovent.Views.Windows"
        xmlns:vm="clr-namespace:Agrovent.ViewModels.Windows"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SaveProgressVM, IsDesignTimeCreatable=True}"
        Title="Сохранение компонента..." Height="400" Width="600"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ListBox для отображения лога -->
        <ListBox Grid.Row="0" x:Name="LogListBox"
                 ItemsSource="{Binding LogMessages}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 IsEnabled="False" />
        <!-- Отключаем интерактивность списка -->

        <!-- StackPanel для кнопок -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CloseButton" Content="Закрыть" Margin="0,0,5,0"
                    Command="{Binding CloseCommand}" />
            <Button x:Name="SaveLogButton" Content="Сохранить лог" Margin="5,0,0,0"
                    Command="{Binding SaveLogCommand}" Visibility="{Binding IsFinished, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>
    </Grid>
</Window>