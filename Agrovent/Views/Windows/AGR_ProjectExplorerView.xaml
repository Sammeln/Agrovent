<Window x:Class="Agrovent.Views.Windows.AGR_ProjectExplorerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:Agrovent.Views.Windows"
        xmlns:tree="clr-namespace:Agrovent.ViewModels.Tree"
        xmlns:vm="clr-namespace:Agrovent.ViewModels.Windows"
        xmlns:bb="clr-namespace:Agrovent.Infrastructure.Behaviours"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:AGR_ProjectExplorerVM, IsDesignTimeCreatable=True}"
        Title="Проводник проектов" Height="600" Width="800"
        ResizeMode="CanResizeWithGrip">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <ToolBar Grid.Row="0" ToolBarTray.IsLocked="True">
            <Button Content="Загрузить" Command="{Binding LoadProjectsCommand}" />
            <Button Content="Добавить папку" Command="{Binding AddFolderCommand}"/>
            <Separator />
            <Button Content="Удалить" Command="{Binding DeleteNodeCommand}"/>
            <Button Content="Переименовать" Command="{Binding RenameNodeCommand}"/>
        </ToolBar>

        <!-- TreeView -->
        <TreeView Grid.Row="1" x:Name="ProjectsTreeView" ItemsSource="{Binding RootNodes}">
            <i:Interaction.Triggers>
                <!-- Привязываем событие SelectedItemChanged к команде в VM -->
                <i:EventTrigger EventName="SelectedItemChanged">
                    <i:InvokeCommandAction Command="{Binding SelectNodeCommand}" PassEventArgsToCommand="True" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <TreeView.Resources>
                <!-- Template для ProjectNode -->
                <HierarchicalDataTemplate DataType="{x:Type tree:AGR_ProjectNode}" ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁 " />
                        <!-- Иконка папки -->
                        <TextBlock Text="{Binding DatabaseId}"/>
                        <TextBlock Text=" "/>
                        <TextBlock Text="{Binding Name}" />
                    </StackPanel>
                </HierarchicalDataTemplate>
                <!-- Template для ComponentNode -->
                <DataTemplate DataType="{x:Type tree:AGR_ComponentNode}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧩 " />
                        <!-- Иконка компонента -->
                        <TextBlock Text="{Binding Name}" />
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>
            <TreeView.ItemContainerStyle>
                <Style TargetType="{x:Type TreeViewItem}">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                    <!-- Контекстное меню можно добавить здесь -->
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </Grid>
</Window>